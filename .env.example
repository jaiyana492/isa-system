# ═══════════════════════════════════════════════════════════════════════════════
# CorePilora AI ISA — Environment Configuration
# Copy this file to .env and fill in every value before running the application.
# NEVER commit .env to git. It is in .gitignore.
# ═══════════════════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────────────────
# DATABASE — PostgreSQL (asyncpg driver)
# Format: postgresql+asyncpg://user:password@host:port/database
# Local Docker example: postgresql+asyncpg://corepilora:secret@localhost:5432/isa_db
# Managed (Railway, Supabase, Neon, RDS): copy connection string from dashboard
# ───────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://corepilora:yourpassword@localhost:5432/isa_db


# ───────────────────────────────────────────────────────────────────────────────
# REDIS — Session cache, lead locks, rate limiting, nurture queue
# Local Docker example: redis://localhost:6379
# Managed (Railway, Upstash): copy URL from dashboard
# ───────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379


# ───────────────────────────────────────────────────────────────────────────────
# SECURITY — Webhook Signature Verification
# Set this to any strong random string (min 32 chars).
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
# All incoming webhooks must include this as X-Webhook-Signature header.
# ───────────────────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=your-webhook-secret-min-32-chars


# ───────────────────────────────────────────────────────────────────────────────
# GROQ — LLM for all conversation nodes (Jaiyana's brain)
# Sign up: https://console.groq.com
# Free tier: 14,400 requests/day on llama3-70b — sufficient for testing
# Production: upgrade to paid plan for rate limit headroom
# ───────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192


# ───────────────────────────────────────────────────────────────────────────────
# TELNYX — Inbound/outbound calls and SMS
# Sign up: https://portal.telnyx.com
# Get API key: Account → Keys & Credentials → Create key
# Phone number format: +12145551234 (E.164)
# Create a TeXML Application and assign your number to it.
# Webhook URL: https://your-domain.onrender.com/api/v1/voice/incoming
# ───────────────────────────────────────────────────────────────────────────────
TELNYX_API_KEY=KEYxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELNYX_PHONE_NUMBER=+12145551234
TELNYX_PUBLIC_KEY=


# ───────────────────────────────────────────────────────────────────────────────
# DEEPGRAM — Speech-to-Text for live voice transcription
# Sign up: https://console.deepgram.com
# Free tier: $200 credit — sufficient for development and demo
# ───────────────────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here


# ───────────────────────────────────────────────────────────────────────────────
# ELEVENLABS — Text-to-Speech (Jaiyana's voice)
# Sign up: https://elevenlabs.io
# Get API key from: Profile → API Keys
# Voice ID: go to Voice Library, clone or select Jaiyana's voice, copy the ID
# Recommended voice: Rachel or Bella for professional real estate tone
# ───────────────────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here


# ───────────────────────────────────────────────────────────────────────────────
# HUBSPOT CRM — Contact sync, deal creation, appointment notes
# Sign up: https://app.hubspot.com
# Get Private App Token: Settings → Integrations → Private Apps → Create App
# Required scopes: crm.objects.contacts.write, crm.objects.deals.write, crm.objects.notes.write
# Portal ID: found in HubSpot URL — app.hubspot.com/contacts/PORTAL_ID
# ───────────────────────────────────────────────────────────────────────────────
HUBSPOT_API_KEY=pat-na1-your-private-app-token
HUBSPOT_PORTAL_ID=12345678


# ───────────────────────────────────────────────────────────────────────────────
# APPLICATION
# APP_ENV: development | staging | production
# ISA_NAME: The name Jaiyana uses to introduce herself
# PRIMARY_MARKET: Default market when no market is detected
# APP_DOMAIN: Your public domain (used for Telnyx callback URLs and WebSocket stream)
#   - Local testing: use ngrok → ngrok http 8000 → copy the https URL (no trailing slash)
#   - Production: your-domain.com
# ALLOWED_ORIGINS: Comma-separated CORS origins
#   - Development: * (allow all)
#   - Production: https://your-frontend.com,https://admin.your-domain.com
# ───────────────────────────────────────────────────────────────────────────────
APP_ENV=development
ISA_NAME=Jaiyana
PRIMARY_MARKET=Dallas-Houston
APP_DOMAIN=localhost
ALLOWED_ORIGINS=*
